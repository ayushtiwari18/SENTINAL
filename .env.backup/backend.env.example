# BACKUP — Original backend/.env.example
# Backed up during Phase 3 of environment centralization.
# The canonical source is now the root /.env.example

NODE_ENV=development
PORT=3000

# ── MongoDB Atlas (required) ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sentinal

# ── Downstream Python microservices ─────────────────────────────────
DETECTION_ENGINE_URL=http://localhost:8002
PCAP_SERVICE_URL=http://localhost:8003
Nexus_URL=http://localhost:8004

# ── Atlas Search index name ─────────────────────────────────────────────
ATLAS_SEARCH_INDEX=attackevents_search

# JWT_SECRET=change_me_in_production
