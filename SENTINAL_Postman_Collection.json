    "version": "1.0.0"
  },
  "variable": [
    { "key": "base",      "value": "http://98.82.8.144:3000",  "type": "string" },
    { "key": "detection", "value": "http://98.82.8.144:8002",  "type": "string" },
    { "key": "pcap",      "value": "http://98.82.8.144:8003",  "type": "string" },
    { "key": "armoriq",   "value": "http://98.82.8.144:8004",  "type": "string" },
    { "key": "attackId",  "value": "",                         "type": "string" }
  ],
  "item": [

    {
      "name": "00 — Health Checks (All Services)",
      "description": "Verify all 4 backend services are live before running any tests.",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base}}/health", "host": ["{{base}}"], "path": ["health"] }
          },
          "event": [{
            "listen": "test",
