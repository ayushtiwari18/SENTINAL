# sentinel-middleware environment variables
# Copy to .env in your application and fill in the values.

# Required: your app's identifier in SENTINAL
SENTINAL_PROJECT_ID=my-app

# Required: URL of the SENTINAL Gateway
SENTINAL_GATEWAY_URL=http://localhost:3000

# Optional: API key for Gateway auth (not yet enforced — for future use)
SENTINAL_API_KEY=

# Optional: fraction of requests to forward (1.0 = 100%, 0.1 = 10%)
SENTINAL_SAMPLE_RATE=1.0

# Optional: enable debug logging
SENTINAL_DEBUG=false
