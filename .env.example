# =============================================================================
# SENTINAL Response Engine — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control
# =============================================================================

# --- LLM (Required) ----------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# --- ArmorIQ / OpenClaw (Required for approval flow) -------------------------
# Get your API key from: https://platform.armoriq.ai → API Dashboard → API Keys
ARMORIQ_API_KEY=your_armoriq_api_key_here

# URL where the OpenClaw gateway is running locally
# Install: curl -fsSL https://armoriq.ai/install-armorclaw.sh | bash
OPENCLAW_GATEWAY_URL=http://localhost:3000

# Public URL of this SENTINAL instance (for OpenClaw to call back)
SENTINAL_BASE_URL=http://localhost:8004

# --- Telegram Bot (Required for notifications) --------------------------------
# Create a bot via @BotFather on Telegram to get BOT_TOKEN
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your admin Telegram Chat ID (message @userinfobot to find your ID)
TELEGRAM_CHAT_ID=your_admin_chat_id_here

# --- Dashboard Auth (Required for web dashboard) -----------------------------
# Use a strong random secret (min 32 chars)
DASHBOARD_JWT_SECRET=your_very_strong_random_secret_min_32_chars
DASHBOARD_ADMIN_PASSWORD=your_secure_admin_password

# --- Policy Thresholds -------------------------------------------------------
# Actions with confidence >= AUTO_EXECUTE_CONFIDENCE are executed automatically
AUTO_EXECUTE_CONFIDENCE=0.95

# Actions with confidence between HUMAN_REVIEW_CONFIDENCE and AUTO_EXECUTE_CONFIDENCE
# are held for human approval via Telegram/Dashboard
HUMAN_REVIEW_CONFIDENCE=0.70

# --- IP Enforcement Backend --------------------------------------------------
# Options:
#   noop      = Dry-run mode — logs actions but doesn't execute (safe for testing)
#   ufw       = Ubuntu Uncomplicated Firewall
#   iptables  = Direct iptables rules (requires root)
FIREWALL_BACKEND=noop

# --- SENTINAL Server ---------------------------------------------------------
SENTINAL_HOST=0.0.0.0
SENTINAL_PORT=8004
LOG_LEVEL=INFO
