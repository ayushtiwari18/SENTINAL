# ============================================================
# SENTINAL — Central Environment Configuration
# ============================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# NEVER commit your actual .env file to Git.
# This file contains SAFE PLACEHOLDER values only.
# ============================================================


# ── SYSTEM ───────────────────────────────────────────────────
# Runtime mode: development | production | test
NODE_ENV=development

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info


# ── NETWORK ──────────────────────────────────────────────────
# Host to bind all services to (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Public-facing base URL of your deployment
# Local:  http://localhost
# AWS EC2: http://<your-ec2-public-ip>
# Domain: https://yourdomain.com
PUBLIC_URL=http://localhost


# ── DATABASE ─────────────────────────────────────────────────
# MongoDB connection string (REQUIRED — system exits without this)
#
# Local MongoDB:
#   MONGO_URI=mongodb://localhost:27017/sentinel
#
# MongoDB Atlas (recommended for cloud):
#   MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sentinel
#
# Free Atlas cluster: https://www.mongodb.com/cloud/atlas/register
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/sentinel

# Atlas full-text search index name (create in Atlas UI → Search)
ATLAS_SEARCH_INDEX=attackevents_search


# ── SERVICE PORTS ────────────────────────────────────────────
# Each microservice listens on its own port.
# Do NOT assign the same port to two services.

# Node.js Express Gateway
GATEWAY_PORT=3000

# Python FastAPI — Detection Engine
DETECTION_PORT=8002

# Python FastAPI — PCAP Processor
PCAP_PORT=8003

# Python FastAPI — SENTINAL Response Engine
Nexus_PORT=8004

# React Vite Dashboard (dev server only — in prod, serve static build)
DASHBOARD_PORT=5173


# ── INTERNAL SERVICE URLs ────────────────────────────────────
# These are how services call each other internally.
#
# Local development: use localhost
#   DETECTION_URL=http://localhost:8002
#
# AWS EC2 (all services on same machine): still use localhost
#   DETECTION_URL=http://localhost:8002
#
# AWS separate instances: use private IP or DNS
#   DETECTION_URL=http://10.0.1.25:8002
DETECTION_URL=http://localhost:8002
PCAP_URL=http://localhost:8003
Nexus_URL=http://localhost:8004

# Gateway URL (used by Nexus agent to call back to gateway)
GATEWAY_URL=http://localhost:3000


# ── SECURITY ─────────────────────────────────────────────────
# IMPORTANT: Change these before any production deployment!
# Use a long random string (min 32 characters recommended)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret_string
API_SECRET=change_me_to_another_long_random_secret_string


# ── AI SERVICES ──────────────────────────────────────────────
# Google Gemini API Key (used by Nexus agent for LLM decisions)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# ── PCAP PROCESSOR — Detection Thresholds ────────────────────
# Fine-tune these based on your network traffic baseline.
# Higher values = less sensitive (fewer false positives)
# Lower values  = more sensitive (catches more attacks)

BATCH_SIZE=50
HTTP_TIMEOUT=10.0
FLOW_TIMEOUT=120
MAX_PCAP_SIZE_MB=500

PORT_SCAN_THRESHOLD=15
SYN_FLOOD_PPS_THRESHOLD=100
DDOS_PPS_THRESHOLD=500
DNS_AMP_RATIO_THRESHOLD=5.0
ICMP_FLOOD_PPS_THRESHOLD=50
BRUTE_FORCE_THRESHOLD=10

LOG_DIR=logs


# ── DEPLOYMENT ───────────────────────────────────────────────
# Environment tag (for logging and monitoring)
ENVIRONMENT=local

# AWS region (if deploying to AWS)
REGION=us-east-1
