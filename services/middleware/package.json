{
  "name": "sentinel-middleware",
  "version": "1.0.0",
  "description": "Drop-in Express/Fastify middleware that streams HTTP request logs to the SENTINAL Gateway for real-time attack detection.",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./express": "./src/adapters/express.js",
    "./fastify": "./src/adapters/fastify.js"
  },
  "scripts": {
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "keywords": ["security", "middleware", "waf", "intrusion-detection", "sentinal", "express", "fastify"],
  "author": "SENTINAL",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "express": "^4.18.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
