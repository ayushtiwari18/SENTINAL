# SENTINAL Backend — Environment Variables
# Copy to root .env and fill in your values
# DO NOT commit your actual .env file

NODE_ENV=development

# ── Gateway ────────────────────────────────────────────────────────────────────────────
GATEWAY_PORT=3000

# ── Microservice ports (used by envValidator.js) ─────────────────────────────
DETECTION_PORT=8002
PCAP_PORT=8003
NEXUS_PORT=8004

# ── Microservice URLs (used at runtime to call services) ─────────────────────
DETECTION_ENGINE_URL=http://localhost:8002
PCAP_SERVICE_URL=http://localhost:8003
NEXUS_URL=http://localhost:8004
# Nexus agent is called AFTER AttackEvent is saved.
# If Nexus is offline, the detection pipeline is unaffected.

# ── MongoDB Atlas (required) ─────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sentinal

# ── Auth ─────────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_string

# ── Gemini AI ────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Atlas Search ────────────────────────────────────────────────────────────────────────
ATLAS_SEARCH_INDEX=attackevents_search

# ── Logging ─────────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
