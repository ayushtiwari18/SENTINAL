# SENTINAL Backend — Environment Variables
# Copy to .env and fill in your values
# DO NOT commit your actual .env file

NODE_ENV=development
PORT=3000

# ── MongoDB Atlas (required) ────────────────────────────────────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
# Get free cluster: https://mlh.link/mongodb-free
# Student $50 credit: https://mlh.link/mongodb
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sentinal

# ── Downstream Python microservices ─────────────────────────────────────────────
DETECTION_ENGINE_URL=http://localhost:8002
PCAP_SERVICE_URL=http://localhost:8003
ARMORIQ_URL=http://localhost:8004
# ArmorIQ agent is called AFTER AttackEvent is saved.
# If ArmorIQ is offline, the detection pipeline is unaffected.

# ── Atlas Search index name (used in atlasSearchController.js) ──────────────────
# Create this index in Atlas UI -> Search -> Create Index -> attackevents collection
ATLAS_SEARCH_INDEX=attackevents_search

# JWT (if auth is added)
# JWT_SECRET=change_me_in_production
