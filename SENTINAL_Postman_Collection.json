    {
      "name": "05 — Action Queue — Human Approval Workflow",
      "description": "After firing a critical attack trigger, use these requests to approve or reject blocked actions.\n\nWorkflow:\n1. Run [TRIGGER] Brute Force Critical from folder 04\n2. GET /api/actions/pending — copy an action ID\n3. POST approve or reject with that ID",
      "item": [
        {
          "name": "GET Pending Actions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base}}/api/actions/pending", "host": ["{{base}}"], "path": ["api", "actions", "pending"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Pending actions fetched', () => pm.response.to.have.status(200));",
              "const actions = pm.response.json().data;",
              "if (actions && actions.length > 0) {",
              "  pm.collectionVariables.set('pendingActionId', actions[0]._id);",
              "  console.log('Saved action ID:', actions[0]._id);",
              "}"
            ]}
          }]
        },
        {
          "name": "POST Approve Action",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base}}/api/actions/{{pendingActionId}}/approve",
              "host": ["{{base}}"],
              "path": ["api", "actions", "{{pendingActionId}}", "approve"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approvedBy\": \"demo-judge\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Action approved', () => pm.response.to.have.status(200));",
              "pm.test('Success true', () => pm.expect(pm.response.json().success).to.be.true);"
            ]}
          }]
        },
        {
          "name": "POST Reject Action",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base}}/api/actions/{{pendingActionId}}/reject",
              "host": ["{{base}}"],
              "path": ["api", "actions", "{{pendingActionId}}", "reject"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rejectedBy\": \"demo-judge\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Action rejected', () => pm.response.to.have.status(200));"
            ]}
          }]
        }
      ]
    },

